{
    "name": "ramon/stickers",
    "version": "2.0.5-beta",
    "description": "Sticker manager for Flarum with native support for animated TGS and Lottie stickers.",
    "keywords": [
        "flarum",
        "stickers",
        "tgs",
        "lottie",
        "animated"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Ramon Guilherme",
            "email": "ramon@ramonguilherme.com.br",
            "homepage": "https://ramonguilherme.com.br"
        }
    ],
    "require": {
        "flarum/core": "^1.8.10"
    },
    "autoload": {
        "psr-4": {
            "Ramon\\Stickers\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Stickers",
            "category": "feature",
            "icon": {
                "backgroundColor": "#e67e22",
                "backgroundImage": "url('data:image/svg+xml;base64,')",
                "backgroundSize": "58%",
                "backgroundRepeat": "no-repeat",
                "backgroundPosition": "center"
            }
        }
    }
}
